# 使用するAPIキーのみ記入してください。空欄または未記入の行はそのLLMが
# オーケストレーション対象から自動的に除外されます。

# Gemini API（必須・初回は /opt/gemini-ui/.env の GOOGLE_API_KEY と同値を設定）
GEMINI_API_KEY=

# 以下は試験的併用予定のため、キー取得後にコメントを外して記入してください
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=

# 任意設定
DEFAULT_LANGUAGE=ja
LOG_LEVEL=INFO

# Streamlit公開設定（/opt 内の PPTX 系アプリに準拠）
LAN_PORT=8517
LAN_BIND=172.16.16.10

# 社内ネットワークがプロキシ経由でのみ外部通信可能な場合に設定(任意)
HTTP_PROXY=
HTTPS_PROXY=
