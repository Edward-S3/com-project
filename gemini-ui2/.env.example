# ── Google Gemini ──
GOOGLE_API_KEY=
# 複数キー（カンマ区切り、レート制限時にローテーション）
# GOOGLE_API_KEYS=key1,key2

# ── OpenAI ──
# OPENAI_API_KEY=
# OPENAI_API_KEYS=

# ── Anthropic ──
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEYS=

# ── ローカル LLM: Gemma 4（Ollama） ──
# 2026-04-02 リリース。インストール: bash /opt/gemini-ui/scripts/install_gemma4.sh all
# OLLAMA_ENABLED=0  # ローカル LLM を完全に無効化する場合
OLLAMA_BASE_URL=http://127.0.0.1:11434
# 自動選択ルーター（未設定時は Gemma 4 E2B → llama3.2 の順で自動検出）
LOCAL_LLM_ROUTER_MODEL=gemma4:e2b

# ── 管理 ──
ADMIN_PASSWORD=
# ランチャー負荷 API のトークン署名（未設定時は ADMIN_PASSWORD を使用）
# SERVER_STATUS_SECRET=
