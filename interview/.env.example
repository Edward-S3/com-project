# API keys (set real values in .env; never commit .env)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Role-based provider selection (gemini / openai / anthropic / xai)
ROLE_PARTNER=gemini
ROLE_JUDGE=gemini
ROLE_PERSONA=gemini

# Model names (confirm latest names from official docs before use)
# See docs/notes/live_api_survey.md (surveyed 2026-07-13, amended 2026-07-14)
MODEL_GEMINI_LIVE=gemini-3.1-flash-live-preview
# Fallback if 3.1 unavailable: gemini-2.5-flash-native-audio-preview-12-2025
MODEL_GEMINI_TEXT=gemini-2.5-flash
MODEL_OPENAI=gpt-4o-mini
MODEL_ANTHROPIC=claude-3-5-haiku-latest
MODEL_XAI=grok-2-latest

# Live API prebuilt voices (changeable without code edit)
VOICE_SUBORDINATE=Fenrir
VOICE_SUPERVISOR=Kore

ADMIN_PASSWORD=change_me
SESSION_MAX_MINUTES=30

# mkcert HTTPS (P3)
SSL_CERTFILE=certs/localhost+4.pem
SSL_KEYFILE=certs/localhost+4-key.pem
