[Unit]
Description=PPTX Auto Generator (Port 8514)
After=network.target

[Service]
User=root
WorkingDirectory=/opt/pptx-gen
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/pptx-gen/venv/bin/streamlit run app.py \
    --server.port 8514 \
    --server.address 172.16.16.10 \
    --server.headless true \
    --browser.gatherUsageStats false \
    --server.maxUploadSize 50
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
