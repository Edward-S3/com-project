[Unit]
Description=Image PPTX Converter (Port 8515)
After=network.target

[Service]
User=root
WorkingDirectory=/opt/img2pptx
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/img2pptx/venv/bin/streamlit run app.py \
    --server.port 8515 \
    --server.address 172.16.16.10 \
    --server.headless true \
    --browser.gatherUsageStats false \
    --server.maxUploadSize 50
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
