[Unit]
Description=FAQ Bot Instance A (Port 8501)
After=network.target

[Service]
User=root
WorkingDirectory=/opt/faq-bot
EnvironmentFile=-/opt/faq-bot/.env
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/faq-bot/venv/bin/streamlit run app.py --server.port 8501 --server.address 172.16.16.10 --server.headless true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
