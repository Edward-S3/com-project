# /opt/pptx-gen-an 専用の環境変数
# このファイルを .env にコピーして API キーを設定してください:
#   cp .env.example .env

# Anthropic API キー（必須）
# このキーは pptx-gen-an 専用です。他アプリ（gemini-ui 等）では使用しないでください。
# 複数キーはカンマ区切り: ANTHROPIC_API_KEYS=key1,key2
ANTHROPIC_API_KEY=

# 生成モデル（任意）
# PPTX_STRUCTURED_MODEL=claude-sonnet-4-6
# PPTX_FAST_MODEL=claude-haiku-4-5-20251001

OUTPUT_DIR=./output
PPTX_MAX_SOURCE_CHARS=120000
