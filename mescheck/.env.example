# Azure AD アプリ登録（Microsoft Entra ID）
# ポータル: https://entra.microsoft.com → アプリの登録 → 新規登録
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# OAuth リダイレクト URI（Azure 側にも同じ URI を登録すること）
# HTTPS（Azure 登録用・推奨）: https://172.16.16.10/mescheck/
# HTTP 直接アクセス（OAuth 非対応）: http://172.16.16.10:8511/
REDIRECT_URI=https://172.16.16.10/mescheck/

# 本文要約の最大文字数
SUMMARY_MAX_LENGTH=200
